<ctrl:ThemedWindow x:Class="NetThrottle.App.Dialogs.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:NetThrottle.App.Controls"
        Title="NetThrottle" Width="430" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1F" FontSize="13" TextOptions.TextFormattingMode="Ideal">
    <ctrl:ThemedWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetThrottle;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ctrl:ThemedWindow.Resources>

    <StackPanel Margin="22,20">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="21"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button x:Name="PrimaryButton" MinWidth="88" Height="30" IsDefault="True"
                    Click="Primary_Click" Margin="0,0,8,0" Style="{StaticResource AccentButton}" />
            <Button x:Name="SecondaryButton" MinWidth="88" Height="30" IsCancel="True"
                    Click="Secondary_Click" Visibility="Collapsed" />
        </StackPanel>
    </StackPanel>
</ctrl:ThemedWindow>
