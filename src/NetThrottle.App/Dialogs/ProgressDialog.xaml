<ctrl:ThemedWindow x:Class="NetThrottle.App.Dialogs.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:NetThrottle.App.Controls"
        Title="NetThrottle" Width="400" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1F" FontSize="13" TextOptions.TextFormattingMode="Ideal">
    <ctrl:ThemedWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetThrottle;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ctrl:ThemedWindow.Resources>

    <StackPanel Margin="22,20">
        <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" />
        <ProgressBar x:Name="Bar" Height="8" Margin="0,14,0,8" Minimum="0" Maximum="100"
                     Background="{StaticResource ControlBackgroundBrush}" Foreground="{StaticResource AccentBrush}"
                     BorderThickness="0">
            <ProgressBar.Template>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" SnapsToDevicePixels="True">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="4" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </ProgressBar.Template>
        </ProgressBar>
        <Grid>
            <TextBlock x:Name="PercentText" Text="0%" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
            <Button x:Name="CancelButton" HorizontalAlignment="Right" MinWidth="88" Height="30" Click="Cancel_Click" />
        </Grid>
    </StackPanel>
</ctrl:ThemedWindow>
