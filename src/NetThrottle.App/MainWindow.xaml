<ctrl:ThemedWindow x:Class="NetThrottle.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetThrottle.App.ViewModels"
        xmlns:conv="clr-namespace:NetThrottle.App.Converters"
        xmlns:loc="clr-namespace:NetThrottle.App.Localization"
        xmlns:ctrl="clr-namespace:NetThrottle.App.Controls"
        xmlns:common="clr-namespace:NetThrottle.App.Common"
        mc:Ignorable="d"
        Title="NetThrottle" Height="600" Width="1020" MinWidth="860" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        FontSize="13" Background="#FF1E1E1F" Icon="/icon.ico"
        TextOptions.TextFormattingMode="Ideal"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetThrottle;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Command="{Binding ToggleEngineCommand}" Content="{Binding ToggleButtonText}"
                        Padding="16,6" FontWeight="Bold" BorderThickness="0" Foreground="White" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF2E7D32" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EngineEnabled}" Value="True">
                                    <Setter Property="Background" Value="#FFC62828" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0" FontWeight="SemiBold" />

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="18,0,0,0">
                    <TextBlock Text="{loc:Tr Toolbar.Filter}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="200" VerticalAlignment="Center" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <CheckBox DockPanel.Dock="Left" Content="{loc:Tr Toolbar.LimitedOnly}" VerticalAlignment="Center" Margin="16,0,0,0"
                          IsChecked="{Binding ShowOnlyLimited}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{loc:Tr Toolbar.RefreshApps}" Command="{Binding RefreshProcessesCommand}" Margin="6,0" />
                    <Button Content="{loc:Tr Toolbar.CheckUpdates}" Command="{Binding CheckUpdateCommand}" Margin="6,0" />
                    <Button Content="{loc:Tr Toolbar.Settings}" Click="OnSettingsClick" Margin="6,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel LastChildFill="False">
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="{loc:Tr Status.Mode}" />
                    <Run Text="{Binding ModeText, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Text="{Binding SettingsLocation}" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis"
                           MaxWidth="560" ToolTip="{Binding SettingsLocation}" />
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" DockPanel.Dock="Right">
                    <Run Text="v" /><Run Text="{Binding AppVersion, Mode=OneWay}" />
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Run Text="Σ" Foreground="{StaticResource TextMutedBrush}" /><Run Text="  ↓ " Foreground="{StaticResource DownArrowBrush}" /><Run Text="{Binding TotalDownText, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" /><Run Text="    ↑ " Foreground="{StaticResource UpArrowBrush}" /><Run Text="{Binding TotalUpText, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Process list -->
        <DataGrid ItemsSource="{Binding EntriesView}" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{loc:Tr Col.Process}" Width="2*" SortMemberPath="ProcessName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" Margin="6,0"
                                       TextTrimming="CharacterEllipsis" HorizontalAlignment="Stretch"
                                       ToolTip="{Binding ProcessName}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                <Setter Property="ToolTip" Value="{loc:Tr Tooltip.NotRunning}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="{loc:Tr Col.Protocol}" Width="104" SortMemberPath="Protocol">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Margin="2" Height="26"
                                      SelectedItem="{Binding Protocol, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.ProtocolOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="128" SortMemberPath="DownloadLimit"
                                    Binding="{Binding DownloadLimit, UpdateSourceTrigger=LostFocus, StringFormat=0.#}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="{loc:Tr Tooltip.DownLimit}">
                            <Path Data="{StaticResource DownArrowGeometry}" Fill="{StaticResource DownArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock VerticalAlignment="Center"><Run Text="{loc:Tr Col.Down}" /><Run Text=" " /><Run Text="{Binding Label, Source={x:Static common:DisplayUnits.Instance}, Mode=OneWay}" /></TextBlock>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="88" IsReadOnly="True" SortMemberPath="CurrentDownloadBps" Binding="{Binding CurrentDownload}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="{loc:Tr Tooltip.DownLive}">
                            <Path Data="{StaticResource DownArrowGeometry}" Fill="{StaticResource DownArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{loc:Tr Col.Live}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="128" SortMemberPath="UploadLimit"
                                    Binding="{Binding UploadLimit, UpdateSourceTrigger=LostFocus, StringFormat=0.#}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="{loc:Tr Tooltip.UpLimit}">
                            <Path Data="{StaticResource UpArrowGeometry}" Fill="{StaticResource UpArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock VerticalAlignment="Center"><Run Text="{loc:Tr Col.Up}" /><Run Text=" " /><Run Text="{Binding Label, Source={x:Static common:DisplayUnits.Instance}, Mode=OneWay}" /></TextBlock>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="88" IsReadOnly="True" SortMemberPath="CurrentUploadBps" Binding="{Binding CurrentUpload}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="{loc:Tr Tooltip.UpLive}">
                            <Path Data="{StaticResource UpArrowGeometry}" Fill="{StaticResource UpArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{loc:Tr Col.Live}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{loc:Tr Col.Clear}" Margin="3" Padding="6,2"
                                    Visibility="{Binding HasLimit, Converter={conv:BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ClearLimitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</ctrl:ThemedWindow>
