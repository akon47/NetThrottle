<Window x:Class="NetThrottle.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetThrottle.App.ViewModels"
        xmlns:conv="clr-namespace:NetThrottle.App.Converters"
        mc:Ignorable="d"
        Title="NetThrottle" Height="600" Width="1020" MinWidth="860" MinHeight="440"
        FontSize="13"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#FF202124" Padding="12,10">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Command="{Binding ToggleEngineCommand}" Padding="16,6"
                        FontWeight="Bold" BorderThickness="0" Foreground="White" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="▶  Start" />
                            <Setter Property="Background" Value="#FF2E7D32" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EngineEnabled}" Value="True">
                                    <Setter Property="Content" Value="■  Stop" />
                                    <Setter Property="Background" Value="#FFC62828" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="#FFE8EAED"
                           VerticalAlignment="Center" Margin="14,0,0,0" FontWeight="SemiBold" />

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="18,0,0,0">
                    <TextBlock Text="Filter:" Foreground="#FFBDC1C6" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="220" VerticalAlignment="Center" VerticalContentAlignment="Center"
                             Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Refresh apps" Command="{Binding RefreshProcessesCommand}" Padding="12,6" Margin="6,0" />
                    <Button Content="Check updates" Command="{Binding CheckUpdateCommand}" Padding="12,6" Margin="6,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Update banner -->
        <Border DockPanel.Dock="Top" Background="#FFFFF3CD" BorderBrush="#FFFFE08A" BorderThickness="0,0,0,1"
                Padding="12,8" Visibility="{Binding IsUpdateAvailable, Converter={conv:BoolToVisibilityConverter}}">
            <DockPanel>
                <TextBlock Text="{Binding UpdateText}" VerticalAlignment="Center" Foreground="#FF664D03" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="Update now" Command="{Binding ApplyUpdateCommand}" Padding="12,4" Margin="6,0" />
                    <Button Content="Skip" Command="{Binding SkipUpdateCommand}" Padding="12,4" Margin="6,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#FFF1F3F4" Padding="12,6">
            <DockPanel LastChildFill="False">
                <TextBlock VerticalAlignment="Center" Foreground="#FF5F6368">
                    <Run Text="Mode:" />
                    <Run Text="{Binding ModeText, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Text="{Binding SettingsLocation}" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="#FF80868B" TextTrimming="CharacterEllipsis" MaxWidth="560" ToolTip="{Binding SettingsLocation}" />
                <TextBlock VerticalAlignment="Center" Foreground="#FF5F6368" DockPanel.Dock="Right">
                    <Run Text="v" /><Run Text="{Binding AppVersion, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Process list -->
        <DataGrid ItemsSource="{Binding EntriesView}" AutoGenerateColumns="False" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="32"
                  SelectionMode="Single" Margin="10" BorderThickness="1" BorderBrush="#FFDADCE0"
                  AlternatingRowBackground="#FFFAFAFA"
                  EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Process (image name)" Width="2*" SortMemberPath="ProcessName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" Margin="6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF202124" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                <Setter Property="Foreground" Value="#FFD32F2F" />
                                                <Setter Property="ToolTip" Value="Not running — the limit re-applies automatically when it starts again." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Protocol" Width="104">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Margin="2" BorderThickness="0" Background="Transparent"
                                      SelectedItem="{Binding Protocol, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.ProtocolOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Down KB/s (0=∞)" Width="118"
                                    Binding="{Binding DownloadKBps, UpdateSourceTrigger=LostFocus, StringFormat=0.#}" />
                <DataGridTextColumn Header="↓ live" Width="88" IsReadOnly="True" Binding="{Binding CurrentDownload}" />
                <DataGridTextColumn Header="Up KB/s (0=∞)" Width="118"
                                    Binding="{Binding UploadKBps, UpdateSourceTrigger=LostFocus, StringFormat=0.#}" />
                <DataGridTextColumn Header="↑ live" Width="88" IsReadOnly="True" Binding="{Binding CurrentUpload}" />

                <DataGridTemplateColumn Header="" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Clear" Margin="3" Padding="6,2"
                                    Visibility="{Binding HasLimit, Converter={conv:BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ClearLimitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
