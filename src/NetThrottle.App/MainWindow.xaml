<Window x:Class="NetThrottle.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetThrottle.App.ViewModels"
        xmlns:conv="clr-namespace:NetThrottle.App.Converters"
        mc:Ignorable="d"
        Title="NetThrottle" Height="600" Width="1020" MinWidth="860" MinHeight="440"
        FontSize="13" Background="#FF1E1E1F" Icon="/icon.ico"
        TextOptions.TextFormattingMode="Ideal"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetThrottle;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Command="{Binding ToggleEngineCommand}" Padding="16,6"
                        FontWeight="Bold" BorderThickness="0" Foreground="White" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="▶  Start" />
                            <Setter Property="Background" Value="#FF2E7D32" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EngineEnabled}" Value="True">
                                    <Setter Property="Content" Value="■  Stop" />
                                    <Setter Property="Background" Value="#FFC62828" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0" FontWeight="SemiBold" />

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="18,0,0,0">
                    <TextBlock Text="Filter:" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="220" VerticalAlignment="Center" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <CheckBox DockPanel.Dock="Left" Content="Limited only" VerticalAlignment="Center" Margin="16,0,0,0"
                          IsChecked="{Binding ShowOnlyLimited}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Refresh apps" Command="{Binding RefreshProcessesCommand}" Margin="6,0" />
                    <Button Content="Check updates" Command="{Binding CheckUpdateCommand}" Margin="6,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Update banner -->
        <Border DockPanel.Dock="Top" Background="#FF332B00" BorderBrush="#FF5A4A00" BorderThickness="0,0,0,1"
                Padding="12,8" Visibility="{Binding IsUpdateAvailable, Converter={conv:BoolToVisibilityConverter}}">
            <DockPanel>
                <TextBlock Text="{Binding UpdateText}" VerticalAlignment="Center" Foreground="{StaticResource AmberBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="Update now" Command="{Binding ApplyUpdateCommand}" Margin="6,0" />
                    <Button Content="Skip" Command="{Binding SkipUpdateCommand}" Margin="6,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel LastChildFill="False">
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="Mode:" />
                    <Run Text="{Binding ModeText, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Text="{Binding SettingsLocation}" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis"
                           MaxWidth="560" ToolTip="{Binding SettingsLocation}" />
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" DockPanel.Dock="Right">
                    <Run Text="v" /><Run Text="{Binding AppVersion, Mode=OneWay}" />
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Run Text="Σ" Foreground="{StaticResource TextMutedBrush}" /><Run Text="  ↓ " Foreground="{StaticResource DownArrowBrush}" /><Run Text="{Binding TotalDownText, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" /><Run Text="    ↑ " Foreground="{StaticResource UpArrowBrush}" /><Run Text="{Binding TotalUpText, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Process list -->
        <DataGrid ItemsSource="{Binding EntriesView}" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Process (image name)" Width="2*" SortMemberPath="ProcessName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" Margin="6,0"
                                       TextTrimming="CharacterEllipsis" HorizontalAlignment="Stretch"
                                       ToolTip="{Binding ProcessName}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                <Setter Property="ToolTip" Value="Not running — the limit re-applies automatically when it starts again." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Protocol" Width="104">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Margin="2" Height="26"
                                      SelectedItem="{Binding Protocol, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.ProtocolOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="128"
                                    Binding="{Binding DownloadKBps, UpdateSourceTrigger=LostFocus, StringFormat=0.#}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="Download limit · 0 = unlimited">
                            <Path Data="{StaticResource DownArrowGeometry}" Fill="{StaticResource DownArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="Down KB/s" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="88" IsReadOnly="True" Binding="{Binding CurrentDownload}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="Live download rate">
                            <Path Data="{StaticResource DownArrowGeometry}" Fill="{StaticResource DownArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="live" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="128"
                                    Binding="{Binding UploadKBps, UpdateSourceTrigger=LostFocus, StringFormat=0.#}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="Upload limit · 0 = unlimited">
                            <Path Data="{StaticResource UpArrowGeometry}" Fill="{StaticResource UpArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="Up KB/s" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="88" IsReadOnly="True" Binding="{Binding CurrentUpload}">
                    <DataGridTextColumn.Header>
                        <StackPanel Orientation="Horizontal" ToolTip="Live upload rate">
                            <Path Data="{StaticResource UpArrowGeometry}" Fill="{StaticResource UpArrowBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="live" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Clear" Margin="3" Padding="6,2"
                                    Visibility="{Binding HasLimit, Converter={conv:BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ClearLimitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
