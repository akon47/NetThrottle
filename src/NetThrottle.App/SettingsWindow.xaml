<ctrl:ThemedWindow x:Class="NetThrottle.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetThrottle.App.ViewModels"
        xmlns:loc="clr-namespace:NetThrottle.App.Localization"
        xmlns:ctrl="clr-namespace:NetThrottle.App.Controls"
        mc:Ignorable="d"
        Title="{loc:Tr Settings.Title}" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#FF1E1E1F" FontSize="13" TextOptions.TextFormattingMode="Ideal"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetThrottle;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,10">
            <Button Content="{loc:Tr Settings.Close}" HorizontalAlignment="Right" MinWidth="92" Click="OnCloseClick" />
        </Border>

        <StackPanel Margin="18">
            <TextBlock Text="{loc:Tr Settings.General}" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{loc:Tr Settings.Language}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Height="30" ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding CurrentLanguage, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <TextBlock Text="{loc:Tr Settings.Startup}" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />
            <CheckBox Content="{loc:Tr Settings.RunAtStartup}" IsChecked="{Binding RunAtStartup}" Margin="0,0,0,10" />
            <CheckBox Content="{loc:Tr Settings.StartMinimized}" IsChecked="{Binding StartMinimized}" Margin="0,0,0,18" />

            <TextBlock Text="{loc:Tr Settings.Display}" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />
            <CheckBox Content="{loc:Tr Settings.UseMegabytes}" IsChecked="{Binding UseMegabytes}" Margin="0,0,0,4" />
        </StackPanel>
    </DockPanel>
</ctrl:ThemedWindow>
